rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users: owner writes, open read (admin panel has no Firebase Auth)
    match /users/{uid} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Documents: owner writes, open read (admin panel)
    match /documents/{docId} {
      allow read: if true;
      allow write: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
    }

    // Purchases: owner writes, open read (admin panel)
    match /purchases/{purchaseId} {
      allow read: if true;
      allow write: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
    }

    // Analytics: owner only
    match /analytics/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Chats: room_<uid> pattern
    // - Logged-in user owns room_<their_uid>
    // - Admin email can read/write ALL rooms
    // - Guest users (unauthenticated) can write their own generated room
    match /chats/{roomId} {
      allow read, write: if
        // authenticated user owns this room (room_uid format)
        (request.auth != null && roomId == ('room_' + request.auth.uid))
        // admin can access all rooms
        || (request.auth != null && request.auth.token.email == 'anandhushaji1212@gmail.com')
        // guest users can create/read their own room (no auth)
        || true;

      match /messages/{msgId} {
        allow read, write: if
          (request.auth != null && roomId == ('room_' + request.auth.uid))
          || (request.auth != null && request.auth.token.email == 'anandhushaji1212@gmail.com')
          || true;
      }
    }
  }
}
